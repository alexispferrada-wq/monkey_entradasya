{
  "name": "living-entradasya",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3002 | xargs kill -9 2>/dev/null; next dev -p 3002",
    "migrate": "drizzle-kit push",
    "build": "next build",
    "build:prod": "drizzle-kit push && next build",
    "start": "lsof -ti:3002 | xargs kill -9 2>/dev/null; next start -p ${PORT:-3002}",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:seed": "dotenv -e .env.local -- tsx lib/db/seed.ts",
    "db:seed-selena": "dotenv -e .env.local -- tsx lib/db/seed-selena.ts",
    "db:reset": "dotenv -e .env.local -- tsx lib/db/reset.ts",
    "db:seed-chatbot": "dotenv -e .env.local -- tsx lib/db/seed-chatbot.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@neondatabase/serverless": "^0.9.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@upstash/ratelimit": "^1.0.0",
    "@upstash/redis": "^1.25.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.4.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.31.4",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.1.2",
    "jose": "^5.6.3",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.12.0",
    "next": "^15.5.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^3.4.0",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.22.8",
    "jest": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5"
  }
}
