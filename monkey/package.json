{
  "name": "monkey-entradasya",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p ${PORT:-3001}",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:seed": "dotenv -e .env.local -- tsx lib/db/seed.ts",
    "db:seed-selena": "dotenv -e .env.local -- tsx lib/db/seed-selena.ts",
    "db:reset": "dotenv -e .env.local -- tsx lib/db/reset.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.4",
    "@upstash/ratelimit": "^1.0.0",
    "@upstash/redis": "^1.25.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.4.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.31.4",
    "jose": "^5.6.3",
    "next": "14.2.5",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^3.4.0",
    "uuid": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^7.4.2",
    "drizzle-kit": "^0.22.8",
    "jest": "^29.7.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.15.7",
    "ts-jest": "^29.1.0",
    "typescript": "^5"
  }
}
